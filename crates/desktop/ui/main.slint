import {
    RouteRow, DashboardSectionRow, DashboardQuotaRow, DashboardBenefitRow,
    DashboardTrendPoint, DashboardSessionRow, DashboardActivityRow, DashboardModelRow,
    HistoryDayRow, ModelUsageRow, ProjectUsageRow, RecentActivityRow, ReminderScopeRow, BenefitLotRow, SessionListRow, SessionDetailBreakdownRow, RestorePointRow, InAppNotificationRow
} from "models.slint";
import { UiTokens } from "tokens.slint";
import { RouteNavItem } from "components/route-nav-item.slint";
import { RouteState } from "components/route-state.slint";
import { InAppNotificationPanel } from "components/in-app-notification-panel.slint";
import { RoutePalette } from "components/command-palette.slint";
import { DashboardView } from "views/dashboard-view.slint";
import { HistoryView } from "views/history-view.slint";
import { ModelsView } from "views/models-view.slint";
import { ProjectsView } from "views/projects-view.slint";
import { ActivityView } from "views/activity-view.slint";
import { NotificationsView } from "views/notifications-view.slint";
import { HelpAboutView } from "views/help-about-view.slint";
import { CompactWidgetView } from "views/compact-widget-view.slint";
import { SessionsView } from "views/sessions-view.slint";
import { DataHealthView } from "views/data-health-view.slint";
import { SettingsView, ReminderCustomLeadRow } from "views/settings-view.slint";
import { Button } from "std-widgets.slint";

export component MainWindow inherits Window {
    in-out property <int> presentation-density-id <=> UiTokens.density-id;
    out property <string> presentation-density-key: root.presentation-density-id == 2 ? "ultra_compact" : (root.presentation-density-id == 1 ? "compact" : "comfortable");
    in-out property <string> presentation-revision: "0";
    out property <length> presentation-space: UiTokens.space;
    out property <length> presentation-radius: UiTokens.radius;
    in property <[RouteRow]> route-rows;
    in property <string> active-route-key;
    in property <string> active-route-label;
    in property <string> active-route-state;
    in property <string> active-route-reasons;
    in property <string> product-generation;
    in property <[DashboardSectionRow]> dashboard-section-rows;
    in property <[DashboardQuotaRow]> dashboard-quota-rows;
    in property <[DashboardBenefitRow]> dashboard-benefit-rows;
    in property <[DashboardTrendPoint]> dashboard-trend-points;
    in property <[DashboardSessionRow]> dashboard-session-rows;
    in property <[DashboardActivityRow]> dashboard-activity-rows;
    in property <[DashboardModelRow]> dashboard-model-rows;
    in property <string> dashboard-header-tokens;
    in property <string> dashboard-header-cost;
    in property <string> dashboard-header-events;
    in property <string> dashboard-header-evidence;
    in property <string> dashboard-code-commits;
    in property <string> dashboard-code-added;
    in property <string> dashboard-code-removed;
    in property <string> dashboard-code-net;
    in property <string> dashboard-code-efficiency;
    in property <string> dashboard-code-evidence;
    in property <[HistoryDayRow]> history-day-rows;
    in property <string> history-state;
    in property <string> history-reasons;
    in property <string> history-range-label;
    in property <string> history-time-zone-label;
    in property <string> history-evidence-label;
    in property <string> history-input-tokens;
    in property <string> history-cached-tokens;
    in property <string> history-output-tokens;
    in property <string> history-reasoning-tokens;
    in property <string> history-total-tokens;
    in property <string> history-cost;
    in property <string> history-events;
    in property <[ModelUsageRow]> model-usage-rows;
    in property <string> models-state;
    in property <string> models-reasons;
    in property <string> models-range-label;
    in property <string> models-time-zone-label;
    in property <string> models-evidence-label;
    in property <string> models-total-tokens;
    in property <string> models-total-availability;
    in property <string> models-cost;
    in property <string> models-cost-availability;
    in property <string> models-cost-evidence-label;
    in property <string> models-events;
    in property <string> models-loaded-label;
    in property <string> models-completeness-label;
    in property <[ProjectUsageRow]> project-usage-rows;
    in property <string> projects-state;
    in property <string> projects-reasons;
    in property <string> projects-usage-range-label;
    in property <string> projects-usage-time-zone-label;
    in property <string> projects-usage-evidence-label;
    in property <string> projects-code-range-label;
    in property <string> projects-code-time-zone-label;
    in property <string> projects-code-evidence-label;
    in property <string> projects-total-tokens;
    in property <string> projects-total-availability;
    in property <string> projects-cost;
    in property <string> projects-cost-availability;
    in property <string> projects-cost-evidence-label;
    in property <string> projects-events;
    in property <string> projects-loaded-label;
    in property <string> projects-completeness-label;
    in property <string> projects-code-coverage-label;
    in property <string> projects-code-completeness-label;
    in property <[RecentActivityRow]> recent-activity-rows;
    in property <string> activity-state;
    in property <string> activity-reasons;
    in property <string> activity-context-label;
    in property <string> activity-evidence-label;
    in property <string> activity-loaded-label;
    in property <string> activity-page-status-label;
    in property <bool> activity-page-available;
    in property <[ReminderScopeRow]> reminder-scope-rows;
    in property <[BenefitLotRow]> benefit-lot-rows;
    in property <string> notifications-state;
    in property <string> notifications-reasons;
    in property <string> notifications-evidence-label;
    in property <string> notifications-loaded-label;
    in property <string> notifications-completeness-label;
    in property <string> help-product-version;
    in property <[SessionListRow]> session-list-rows;
    in property <string> sessions-state;
    in property <string> sessions-reasons;
    in property <string> sessions-evidence-label;
    in property <string> sessions-loaded-label;
    in property <string> sessions-page-status-label;
    in property <int> sessions-selected-row: -1;
    in property <string> session-detail-state: "idle";
    in property <string> session-detail-status-label;
    in property <string> session-detail-evidence-label;
    in property <string> session-detail-period-label;
    in property <string> session-detail-duration-label;
    in property <string> session-detail-event-label;
    in property <string> session-detail-input-availability;
    in property <string> session-detail-input-label;
    in property <string> session-detail-cached-availability;
    in property <string> session-detail-cached-label;
    in property <string> session-detail-output-availability;
    in property <string> session-detail-output-label;
    in property <string> session-detail-reasoning-availability;
    in property <string> session-detail-reasoning-label;
    in property <string> session-detail-total-availability;
    in property <string> session-detail-total-label;
    in property <string> session-detail-cost-availability;
    in property <string> session-detail-cost-label;
    in property <[SessionDetailBreakdownRow]> session-detail-breakdown-rows;
    out property <bool> dashboard-visible: root.active-route-key == "dashboard";
    out property <bool> history-visible: root.active-route-key == "history";
    out property <bool> sessions-visible: root.active-route-key == "sessions";
    out property <bool> models-visible: root.active-route-key == "models";
    out property <bool> projects-visible: root.active-route-key == "projects";
    out property <bool> activity-visible: root.active-route-key == "activity";
    out property <bool> notifications-visible: root.active-route-key == "notifications";
    out property <bool> data-health-visible: root.active-route-key == "data_health";
    out property <bool> settings-visible: root.active-route-key == "settings";
    out property <bool> help-about-visible: root.active-route-key == "help_about";
    out property <bool> compact-widget-visible: root.active-route-key == "compact_widget";
    out property <string> dashboard-layout-mode: root.width < 1010px ? "narrow" : "wide";
    out property <string> sessions-layout-mode: root.width < 1010px ? "narrow" : "wide";
    out property <string> models-layout-mode: root.width < 800px ? "narrow" : "wide";
    out property <string> projects-layout-mode: root.width < 800px ? "narrow" : "wide";
    out property <string> activity-layout-mode: root.width < 800px ? "narrow" : "wide";
    out property <string> settings-layout-mode: settings-view.settings-layout-mode;
    out property <length> settings-reminder-card-bottom: settings-view.reminder-card-bottom;
    out property <length> settings-backup-card-top: settings-view.backup-card-top;
    out property <length> settings-config-card-top: settings-view.config-card-top;
    out property <string> notifications-layout-mode: root.width < 800px ? "narrow" : "wide";
    out property <string> help-about-layout-mode: help-view.layout-mode;
    out property <int> help-about-section-count: help-view.section-count;
    out property <int> compact-widget-quota-count: compact-view.quota-count;
    out property <string> compact-widget-layout-mode: compact-view.layout-mode;
    in property <string> reliable-state-generation;
    in property <string> reliable-state-health;
    in property <bool> reliable-state-safe-mode;
    in property <string> reliable-recovery-kind;
    in property <bool> reliable-non-reconstructible-domains-lost;
    in property <string> settings-health;
    in property <bool> config-import-preview-visible;
    in property <string> config-import-created-label;
    in property <string> config-import-bytes-label;
    in property <string> config-import-changes-label;
    in property <string> reliable-latest-success-label;
    in property <string> reliable-latest-attempt-label;
    in property <string> reliable-successful-count-label;
    in property <string> reliable-failure-count-label;
    in property <string> reliable-published-bytes-label;
    in property <string> reliable-latest-failure-code;
    in property <[RestorePointRow]> restore-point-rows;
    in property <string> reliable-operation-kind;
    in property <string> reliable-operation-phase;
    in property <string> reliable-operation-failure-code;
    in property <bool> reliable-operation-cancel-enabled;
    in-out property <bool> restore-confirmation-visible: false;
    in-out property <int> restore-confirmation-row: -1;
    in-out property <string> restore-confirmation-detail;
    in property <bool> backup-periodic-enabled;
    in property <int> backup-quiet-seconds;
    in property <int> backup-interval-seconds;
    in property <int> backup-retention-budget-mib;
    in-out property <bool> reminder-enabled: false;
    in-out property <bool> reminder-preset-seven-days: false;
    in-out property <bool> reminder-preset-twenty-four-hours: false;
    in-out property <bool> reminder-preset-twelve-hours: false;
    in-out property <bool> reminder-preset-six-hours: false;
    in-out property <bool> reminder-preset-one-hour: false;
    in-out property <[ReminderCustomLeadRow]> reminder-custom-lead-rows;
    in-out property <bool> reminder-dirty: false;
    in-out property <string> reminder-feedback: "Ready to edit reminder profile";
    in property <string> reminder-sync-state;
    in property <string> current-user-startup-status: "unavailable";
    in property <bool> current-user-startup-can-enable: false;
    in property <bool> current-user-startup-can-disable: false;
    in property <bool> current-user-startup-can-repair: false;
    in property <bool> high-contrast: false;
    in property <bool> reduced-motion: false;
    in property <[InAppNotificationRow]> in-app-notification-rows;
    in-out property <bool> in-app-notification-visible: false;
    in-out property <string> in-app-notification-count-label;
    in-out property <bool> command-palette-visible: false;
    in-out property <string> command-palette-query;
    in property <[RouteRow]> command-palette-rows;
    in property <int> command-palette-selected-ordinal: -1;
    callback select-route(string);
    callback open-command-palette();
    callback dismiss-command-palette();
    callback command-palette-query-edited(string);
    callback move-command-palette-selection(int);
    callback activate-command-palette-selection();
    callback activate-command-palette-route(string);
    callback select-session(int);
    callback export-config();
    callback import-config();
    callback confirm-config-import();
    callback cancel-config-import();
    callback backup-normal();
    callback backup-compact();
    callback backup-encrypted(string, string);
    callback verify-backups();
    callback preview-restore(int);
    callback confirm-restore(int, bool);
    callback rebuild-data();
    callback retry-operation();
    callback cancel-operation();
    callback update-backup-policy(bool, int, int, int);
    callback reminder-enabled-edited(bool);
    callback reminder-preset-edited(int, bool);
    callback reminder-custom-lead-edited(int, bool, int, int);
    callback save-reminder-policy();
    callback reset-reminder-recommended();
    callback enable-current-user-startup();
    callback repair-current-user-startup();
    callback disable-current-user-startup();
    callback dismiss-in-app-notifications();
    callback select-presentation-density(int);

    title: "TokenMaster";
    preferred-width: root.compact-widget-visible ? 420px : 1120px;
    preferred-height: root.compact-widget-visible ? 560px : 720px;
    min-width: root.compact-widget-visible ? 360px : 560px;
    min-height: root.compact-widget-visible ? 320px : 480px;
    background: UiTokens.background;
    forward-focus: shell-focus;

    shell-focus := FocusScope {
        width: parent.width;
        height: parent.height;
        KeyBinding {
            keys: @keys(Control + K);
            activated => { root.open-command-palette(); }
        }
        capture-key-pressed(event) => {
            if (event.modifiers.control && event.text == "k") {
                root.open-command-palette();
                return accept;
            }
            return reject;
        }

    VerticalLayout {
        visible: !root.compact-widget-visible;
        Rectangle {
            height: 58px;
            background: UiTokens.surface;
            border-color: UiTokens.border;
            border-width: 1px;

            HorizontalLayout {
                padding-left: UiTokens.space;
                padding-right: UiTokens.space;
                spacing: 12px;

                Text {
                    text: "TokenMaster";
                    color: UiTokens.text-primary;
                    font-size: 20px;
                    font-weight: 800;
                    vertical-alignment: center;
                }
                Text {
                    text: "Local usage intelligence";
                    color: UiTokens.text-secondary;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                Button {
                    text: "Go to route";
                    accessible-label: "Open route palette";
                    clicked => { root.open-command-palette(); }
                }
                Text {
                    text: root.active-route-state;
                    color: root.active-route-state == "ready" ? UiTokens.ready : root.active-route-state == "degraded" ? UiTokens.degraded : root.active-route-state == "waiting" ? UiTokens.waiting : UiTokens.unavailable;
                    vertical-alignment: center;
        }
    }

    }

        HorizontalLayout {
            spacing: 0px;

            Rectangle {
                width: 250px;
                background: UiTokens.surface;
                border-color: UiTokens.border;
                border-width: 1px;

                VerticalLayout {
                    padding: UiTokens.space;
                    spacing: 5px;

                    for route in root.route-rows: RouteNavItem {
                        label: route.label;
                        state: route.state;
                        selected: route.selected;
                        activated => { root.select-route(route.key); }
                    }
                    Rectangle { vertical-stretch: 1; background: transparent; }
                }
            }

            Rectangle {
                background: UiTokens.background;
                horizontal-stretch: 1;

                if root.dashboard-visible: DashboardView {
                    width: parent.width;
                    height: parent.height;
                    sections: root.dashboard-section-rows;
                    quotas: root.dashboard-quota-rows;
                    benefits: root.dashboard-benefit-rows;
                    trend: root.dashboard-trend-points;
                    sessions: root.dashboard-session-rows;
                    activity: root.dashboard-activity-rows;
                    models: root.dashboard-model-rows;
                    header-tokens: root.dashboard-header-tokens;
                    header-cost: root.dashboard-header-cost;
                    header-events: root.dashboard-header-events;
                    header-evidence: root.dashboard-header-evidence;
                    code-commits: root.dashboard-code-commits;
                    code-added: root.dashboard-code-added;
                    code-removed: root.dashboard-code-removed;
                    code-net: root.dashboard-code-net;
                    code-efficiency: root.dashboard-code-efficiency;
                    code-evidence: root.dashboard-code-evidence;
                }

                if root.history-visible: HistoryView {
                    width: parent.width;
                    height: parent.height;
                    rows: root.history-day-rows;
                    state: root.history-state;
                    reasons: root.history-reasons;
                    range-label: root.history-range-label;
                    time-zone-label: root.history-time-zone-label;
                    evidence-label: root.history-evidence-label;
                    input-tokens: root.history-input-tokens;
                    cached-tokens: root.history-cached-tokens;
                    output-tokens: root.history-output-tokens;
                    reasoning-tokens: root.history-reasoning-tokens;
                    total-tokens: root.history-total-tokens;
                    cost: root.history-cost;
                    events: root.history-events;
                }

                if root.sessions-visible: SessionsView {
                    width: parent.width;
                    height: parent.height;
                    rows: root.session-list-rows;
                    state: root.sessions-state;
                    reasons: root.sessions-reasons;
                    evidence-label: root.sessions-evidence-label;
                    loaded-label: root.sessions-loaded-label;
                    page-status-label: root.sessions-page-status-label;
                    selected-row: root.sessions-selected-row;
                    detail-state: root.session-detail-state;
                    detail-status-label: root.session-detail-status-label;
                    detail-evidence-label: root.session-detail-evidence-label;
                    detail-period-label: root.session-detail-period-label;
                    detail-duration-label: root.session-detail-duration-label;
                    detail-event-label: root.session-detail-event-label;
                    detail-input-availability: root.session-detail-input-availability;
                    detail-input-label: root.session-detail-input-label;
                    detail-cached-availability: root.session-detail-cached-availability;
                    detail-cached-label: root.session-detail-cached-label;
                    detail-output-availability: root.session-detail-output-availability;
                    detail-output-label: root.session-detail-output-label;
                    detail-reasoning-availability: root.session-detail-reasoning-availability;
                    detail-reasoning-label: root.session-detail-reasoning-label;
                    detail-total-availability: root.session-detail-total-availability;
                    detail-total-label: root.session-detail-total-label;
                    detail-cost-availability: root.session-detail-cost-availability;
                    detail-cost-label: root.session-detail-cost-label;
                    detail-breakdown-rows: root.session-detail-breakdown-rows;
                    select-row(index) => { root.select-session(index); }
                }

                if root.models-visible: ModelsView {
                    width: parent.width;
                    height: parent.height;
                    rows: root.model-usage-rows;
                    state: root.models-state;
                    reasons: root.models-reasons;
                    range-label: root.models-range-label;
                    time-zone-label: root.models-time-zone-label;
                    evidence-label: root.models-evidence-label;
                    total-tokens: root.models-total-tokens;
                    total-availability: root.models-total-availability;
                    cost: root.models-cost;
                    cost-availability: root.models-cost-availability;
                    cost-evidence-label: root.models-cost-evidence-label;
                    events: root.models-events;
                    loaded-label: root.models-loaded-label;
                    completeness-label: root.models-completeness-label;
                }

                if root.projects-visible: ProjectsView {
                    width: parent.width;
                    height: parent.height;
                    rows: root.project-usage-rows;
                    state: root.projects-state;
                    reasons: root.projects-reasons;
                    usage-range-label: root.projects-usage-range-label;
                    usage-time-zone-label: root.projects-usage-time-zone-label;
                    usage-evidence-label: root.projects-usage-evidence-label;
                    code-range-label: root.projects-code-range-label;
                    code-time-zone-label: root.projects-code-time-zone-label;
                    code-evidence-label: root.projects-code-evidence-label;
                    total-tokens: root.projects-total-tokens;
                    total-availability: root.projects-total-availability;
                    cost: root.projects-cost;
                    cost-availability: root.projects-cost-availability;
                    cost-evidence-label: root.projects-cost-evidence-label;
                    events: root.projects-events;
                    loaded-label: root.projects-loaded-label;
                    completeness-label: root.projects-completeness-label;
                    code-coverage-label: root.projects-code-coverage-label;
                    code-completeness-label: root.projects-code-completeness-label;
                }

                if root.activity-visible: ActivityView {
                    width: parent.width;
                    height: parent.height;
                    rows: root.recent-activity-rows;
                    state: root.activity-state;
                    reasons: root.activity-reasons;
                    context-label: root.activity-context-label;
                    evidence-label: root.activity-evidence-label;
                    loaded-label: root.activity-loaded-label;
                    page-status-label: root.activity-page-status-label;
                    page-available: root.activity-page-available;
                }

                if root.notifications-visible: NotificationsView {
                    width: parent.width;
                    height: parent.height;
                    scope-rows: root.reminder-scope-rows;
                    lot-rows: root.benefit-lot-rows;
                    state: root.notifications-state;
                    reasons: root.notifications-reasons;
                    evidence-label: root.notifications-evidence-label;
                    loaded-label: root.notifications-loaded-label;
                    completeness-label: root.notifications-completeness-label;
                }

                if root.data-health-visible: DataHealthView {
                    width: parent.width;
                    height: parent.height;
                    health: root.reliable-state-health;
                    safe-mode: root.reliable-state-safe-mode;
                    recovery-kind: root.reliable-recovery-kind;
                    non-reconstructible-domains-lost: root.reliable-non-reconstructible-domains-lost;
                    generation: root.reliable-state-generation;
                    latest-success-label: root.reliable-latest-success-label;
                    latest-attempt-label: root.reliable-latest-attempt-label;
                    successful-count-label: root.reliable-successful-count-label;
                    failure-count-label: root.reliable-failure-count-label;
                    published-bytes-label: root.reliable-published-bytes-label;
                    latest-failure-code: root.reliable-latest-failure-code;
                    restore-points: root.restore-point-rows;
                    operation-kind: root.reliable-operation-kind;
                    operation-phase: root.reliable-operation-phase;
                    operation-failure-code: root.reliable-operation-failure-code;
                    operation-cancel-enabled: root.reliable-operation-cancel-enabled;
                    restore-confirmation-visible: root.restore-confirmation-visible;
                    restore-confirmation-row: root.restore-confirmation-row;
                    restore-confirmation-detail: root.restore-confirmation-detail;
                    high-contrast: root.high-contrast;
                    reduced-motion: root.reduced-motion;
                    backup-normal => { root.backup-normal(); }
                    backup-compact => { root.backup-compact(); }
                    backup-encrypted(passphrase, confirmation) => { root.backup-encrypted(passphrase, confirmation); }
                    verify-backups => { root.verify-backups(); }
                    preview-restore(index) => { root.preview-restore(index); }
                    confirm-restore(index, portable-settings) => { root.confirm-restore(index, portable-settings); }
                    dismiss-restore-confirmation => {
                        root.restore-confirmation-visible = false;
                        root.restore-confirmation-row = -1;
                        root.restore-confirmation-detail = "";
                    }
                    rebuild-data => { root.rebuild-data(); }
                    retry-operation => { root.retry-operation(); }
                    cancel-operation => { root.cancel-operation(); }
                }

                settings-view := SettingsView {
                    width: parent.width;
                    height: parent.height;
                    presentation-density-id: root.presentation-density-id;
                    periodic-enabled: root.backup-periodic-enabled;
                    quiet-seconds: root.backup-quiet-seconds;
                    interval-seconds: root.backup-interval-seconds;
                    retention-budget-mib: root.backup-retention-budget-mib;
                    reminder-enabled: root.reminder-enabled;
                    reminder-preset-seven-days: root.reminder-preset-seven-days;
                    reminder-preset-twenty-four-hours: root.reminder-preset-twenty-four-hours;
                    reminder-preset-twelve-hours: root.reminder-preset-twelve-hours;
                    reminder-preset-six-hours: root.reminder-preset-six-hours;
                    reminder-preset-one-hour: root.reminder-preset-one-hour;
                    reminder-custom-lead-rows: root.reminder-custom-lead-rows;
                    reminder-dirty: root.reminder-dirty;
                    reminder-feedback: root.reminder-feedback;
                    reminder-sync-state: root.reminder-sync-state;
                    current-user-startup-status: root.current-user-startup-status;
                    current-user-startup-can-enable: root.current-user-startup-can-enable;
                    current-user-startup-can-disable: root.current-user-startup-can-disable;
                    current-user-startup-can-repair: root.current-user-startup-can-repair;
                    settings-health: root.settings-health;
                    config-import-preview-visible: root.config-import-preview-visible;
                    config-import-created-label: root.config-import-created-label;
                    config-import-bytes-label: root.config-import-bytes-label;
                    config-import-changes-label: root.config-import-changes-label;
                    high-contrast: root.high-contrast;
                    reduced-motion: root.reduced-motion;
                    export-config => { root.export-config(); }
                    import-config => { root.import-config(); }
                    confirm-config-import => { root.confirm-config-import(); }
                    cancel-config-import => { root.cancel-config-import(); }
                    update-backup-policy(enabled, quiet, interval, budget) => { root.update-backup-policy(enabled, quiet, interval, budget); }
                    reminder-enabled-edited(enabled) => { root.reminder-enabled-edited(enabled); }
                    reminder-preset-edited(index, enabled) => { root.reminder-preset-edited(index, enabled); }
                    reminder-custom-lead-edited(index, enabled, value, unit-index) => { root.reminder-custom-lead-edited(index, enabled, value, unit-index); }
                    save-reminder-policy => { root.save-reminder-policy(); }
                    reset-reminder-recommended => { root.reset-reminder-recommended(); }
                    enable-current-user-startup => { root.enable-current-user-startup(); }
                    repair-current-user-startup => { root.repair-current-user-startup(); }
                    disable-current-user-startup => { root.disable-current-user-startup(); }
                    select-presentation-density(index) => { root.select-presentation-density(index); }
                    visible: root.settings-visible;
                }

                help-view := HelpAboutView {
                    width: parent.width;
                    height: parent.height;
                    visible: root.help-about-visible;
                    product-version: root.help-product-version;
                }

                if !root.dashboard-visible && !root.history-visible && !root.sessions-visible && !root.models-visible && !root.projects-visible && !root.activity-visible && !root.notifications-visible && !root.data-health-visible && !root.settings-visible && !root.help-about-visible: RouteState {
                    x: UiTokens.space;
                    y: UiTokens.space;
                    width: parent.width - 2 * UiTokens.space;
                    height: parent.height - 2 * UiTokens.space;
                    route-label: root.active-route-label;
                    state: root.active-route-state;
                    reasons: root.active-route-reasons;
                    generation: root.product-generation;
                }
            }
        }
    }

    compact-view := CompactWidgetView {
        width: parent.width;
        height: parent.height;
        visible: root.compact-widget-visible;
        quotas: root.dashboard-quota-rows;
        state: root.active-route-state;
        reasons: root.active-route-reasons;
        return-dashboard => { root.select-route("dashboard"); }
    }

    if root.in-app-notification-visible: InAppNotificationPanel {
        x: parent.width - self.width - UiTokens.space;
        y: 58px + UiTokens.space;
        width: min(440px, parent.width - 2 * UiTokens.space);
        height: min(460px, parent.height - 58px - 2 * UiTokens.space);
        rows: root.in-app-notification-rows;
        count-label: root.in-app-notification-count-label;
        dismiss => { root.dismiss-in-app-notifications(); }
    }

    RoutePalette {
        width: parent.width;
        height: parent.height;
        palette-open: root.command-palette-visible;
        rows: root.command-palette-rows;
        query: root.command-palette-query;
        selected-ordinal: root.command-palette-selected-ordinal;
        query-edited(query) => { root.command-palette-query-edited(query); }
        dismiss => { root.dismiss-command-palette(); }
        move-selection(delta) => { root.move-command-palette-selection(delta); }
        activate-selection => { root.activate-command-palette-selection(); }
        activate-route(key) => { root.activate-command-palette-route(key); }
    }
    }
}
