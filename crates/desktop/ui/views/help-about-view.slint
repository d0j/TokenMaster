import { UiTokens } from "../tokens.slint";
import { AboutSlint, ScrollView } from "std-widgets.slint";

component HelpSectionCard inherits Rectangle {
    in property <string> title;
    in property <string> summary;
    in property <string> detail;
    in property <string> status;

    background: UiTokens.surface;
    border-color: UiTokens.border;
    border-width: 1px;
    border-radius: UiTokens.radius-lg;
    accessible-role: region;
    accessible-label: root.title + ". " + root.summary + " " + root.detail + " " + root.status;

    VerticalLayout {
        padding: UiTokens.space;
        spacing: UiTokens.space-sm;
        Text {
            text: root.title;
            color: UiTokens.text-primary;
            font-size: 15px;
            font-weight: 750;
        }
        Text {
            text: root.summary;
            color: UiTokens.text-primary;
            font-size: 11px;
            wrap: word-wrap;
            vertical-stretch: 1;
        }
        Text {
            text: root.detail;
            color: UiTokens.text-secondary;
            font-size: 10px;
            wrap: word-wrap;
            vertical-stretch: 1;
        }
        Text {
            text: root.status;
            color: UiTokens.accent;
            font-size: 10px;
            font-weight: 700;
            wrap: word-wrap;
        }
    }
}

component AttributionCard inherits Rectangle {
    background: UiTokens.surface;
    border-color: UiTokens.border;
    border-width: 1px;
    border-radius: UiTokens.radius-lg;
    accessible-role: region;
    accessible-label: @tr("About and licenses. TokenMaster is Apache-2.0 licensed. WhereMyTokens and ccusage are pinned external MIT references, not runtime dependencies. The interface is made with Slint under the selected Royalty-free License 2.0 attribution route.");

    VerticalLayout {
        padding: UiTokens.space;
        spacing: UiTokens.space-xs;
        Text {
            text: @tr("About and licenses");
            color: UiTokens.text-primary;
            font-size: 15px;
            font-weight: 750;
        }
        Text {
            text: @tr("TokenMaster · Apache-2.0");
            color: UiTokens.text-primary;
            font-size: 11px;
            font-weight: 700;
        }
        Text {
            text: @tr("WhereMyTokens and ccusage are pinned external MIT references, not runtime dependencies.");
            color: UiTokens.text-secondary;
            font-size: 10px;
            wrap: word-wrap;
        }
        AboutSlint {
            height: 112px;
            horizontal-stretch: 1;
        }
    }
}

export component HelpAboutView inherits Rectangle {
    in property <string> product-version;
    out property <bool> narrow: root.width < 800px;
    out property <string> layout-mode: root.narrow ? "narrow" : "wide";
    out property <int> section-count: 6;

    background: UiTokens.background;
    accessible-role: region;
    accessible-label: @tr("TokenMaster Help and About. Version {0}. Local-first usage intelligence with explicit data-source, privacy, health, automation, and license truth.", root.product-version);

    ScrollView {
        viewport-width: self.width;
        VerticalLayout {
            width: parent.width;
            padding: UiTokens.space;
            spacing: UiTokens.space;

            Rectangle {
                min-height: root.narrow ? 128px : 112px;
                background: UiTokens.surface-raised;
                border-color: UiTokens.border;
                border-width: 1px;
                border-radius: UiTokens.radius-lg;
                accessible-role: region;
                accessible-label: @tr("TokenMaster version {0}. Fast local-first Codex usage, quota, expiry, and recovery visibility with bounded memory and explicit unavailable truth.", root.product-version);
                VerticalLayout {
                    padding: UiTokens.space;
                    spacing: UiTokens.space-sm;
                    Text {
                        text: @tr("TokenMaster");
                        color: UiTokens.text-primary;
                        font-size: 24px;
                        font-weight: 800;
                    }
                    Text {
                        text: @tr("Version {0} · local-first Windows desktop", root.product-version);
                        color: UiTokens.accent;
                        font-size: 11px;
                        font-weight: 700;
                    }
                    Text {
                        text: @tr("Fast Codex usage, quota, expiry, and recovery visibility with bounded memory and explicit unavailable truth.");
                        color: UiTokens.text-secondary;
                        font-size: 11px;
                        wrap: word-wrap;
                    }
                }
            }

            section-grid := Rectangle {
                property <length> gap: UiTokens.space;
                property <length> card-height: 232px;
                property <length> card-width: root.narrow ? self.width : (self.width - self.gap) / 2;
                height: root.narrow ? 6 * self.card-height + 5 * self.gap : 3 * self.card-height + 2 * self.gap;
                background: transparent;

                HelpSectionCard {
                    x: 0px;
                    y: 0px;
                    width: section-grid.card-width;
                    height: section-grid.card-height;
                    title: @tr("Start here");
                    summary: @tr("Dashboard is the quota-first overview. History, Sessions, Models, Projects, and Activity explain usage. Notifications shows current expiry safety.");
                    detail: @tr("Data Health owns backup, verification, restore, rebuild, and recovery truth. Settings owns backup policy and portable configuration.");
                    status: @tr("Every missing or stale fact stays explicit — never fabricated as zero.");
                }
                HelpSectionCard {
                    x: root.narrow ? 0px : section-grid.card-width + section-grid.gap;
                    y: root.narrow ? section-grid.card-height + section-grid.gap : 0px;
                    width: section-grid.card-width;
                    height: section-grid.card-height;
                    title: @tr("Data sources and truth");
                    summary: @tr("Usage is derived from bounded local Codex history. Plan usage is separate provider evidence from the installed official machine interface when available.");
                    detail: @tr("Local tokens never become a guessed provider allowance. Unsupported, stale, partial, or unavailable evidence remains labelled.");
                    status: @tr("No browser session reuse or private endpoint replay.");
                }
                HelpSectionCard {
                    x: 0px;
                    y: root.narrow ? 2 * (section-grid.card-height + section-grid.gap) : section-grid.card-height + section-grid.gap;
                    width: section-grid.card-width;
                    height: section-grid.card-height;
                    title: @tr("Privacy by design");
                    summary: @tr("No prompts, responses, reasoning, commands, source contents, credentials, or raw absolute paths are retained or exposed.");
                    detail: @tr("Frontend rows carry bounded aggregate facts and stable reason codes, not provider, account, workspace, source, session, lot, or delivery identity.");
                    status: @tr("Local-first archive · no listener · no telemetry surface.");
                }
                HelpSectionCard {
                    x: root.narrow ? 0px : section-grid.card-width + section-grid.gap;
                    y: root.narrow ? 3 * (section-grid.card-height + section-grid.gap) : section-grid.card-height + section-grid.gap;
                    width: section-grid.card-width;
                    height: section-grid.card-height;
                    title: @tr("Health and recovery");
                    summary: @tr("Open Data Health for database health and every backup, verification, restore, rebuild, and recovery operation.");
                    detail: @tr("Settings owns backup policy and portable configuration import/export. Stable failure codes omit paths and raw operating-system messages.");
                    status: @tr("Recovery is verified, bounded, and local.");
                }
                HelpSectionCard {
                    x: 0px;
                    y: root.narrow ? 4 * (section-grid.card-height + section-grid.gap) : 2 * (section-grid.card-height + section-grid.gap);
                    width: section-grid.card-width;
                    height: section-grid.card-height;
                    title: @tr("Automation status");
                    summary: @tr("CLI and stdio MCP are not available in the current build. No local server or listener is active.");
                    detail: @tr("P5 will add strict bounded read-only JSON and stdio MCP for Hermes and other clients. Browser/session automation and automatic benefit activation are not implied.");
                    status: @tr("Current automation authority: none.");
                }
                AttributionCard {
                    x: root.narrow ? 0px : section-grid.card-width + section-grid.gap;
                    y: root.narrow ? 5 * (section-grid.card-height + section-grid.gap) : 2 * (section-grid.card-height + section-grid.gap);
                    width: section-grid.card-width;
                    height: section-grid.card-height;
                }
            }
        }
    }
}
