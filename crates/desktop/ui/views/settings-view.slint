import { Button, CheckBox, ComboBox, ScrollView, SpinBox } from "std-widgets.slint";
import { UiTokens } from "../tokens.slint";
import { DashboardBoardEditorRow } from "../models.slint";

export struct ReminderCustomLeadRow {
    enabled: bool,
    value: int,
    unit-index: int,
}

export component SettingsView inherits Rectangle {
    in property <int> presentation-density-id;
    in property <int> presentation-skin-id;
    in property <int> presentation-color-scheme-id;
    in property <int> presentation-layout-id;
    in property <string> presentation-persistence-state;
    in property <[DashboardBoardEditorRow]> board-editor-rows;
    in property <bool> periodic-enabled;
    in property <int> quiet-seconds;
    in property <int> interval-seconds;
    in property <int> retention-budget-mib;
    in property <bool> reminder-enabled;
    in property <bool> reminder-preset-seven-days;
    in property <bool> reminder-preset-twenty-four-hours;
    in property <bool> reminder-preset-twelve-hours;
    in property <bool> reminder-preset-six-hours;
    in property <bool> reminder-preset-one-hour;
    in property <[ReminderCustomLeadRow]> reminder-custom-lead-rows;
    in property <bool> reminder-dirty;
    in property <string> reminder-feedback;
    in property <string> reminder-sync-state;
    in property <string> settings-health;
    in property <string> current-user-startup-status;
    in property <bool> current-user-startup-can-enable;
    in property <bool> current-user-startup-can-disable;
    in property <bool> current-user-startup-can-repair;
    in property <bool> config-import-preview-visible;
    in property <string> config-import-created-label;
    in property <string> config-import-bytes-label;
    in property <string> config-import-changes-label;
    in property <bool> high-contrast;
    in property <bool> reduced-motion;
    out property <string> settings-layout-mode: root.width < 760px ? "narrow" : "wide";
    out property <length> reminder-card-bottom: reminder-card.y + reminder-card.height;
    out property <length> backup-card-top: backup-card.y;
    out property <length> config-card-top: config-card.y;

    callback export-config();
    callback import-config();
    callback confirm-config-import();
    callback cancel-config-import();
    callback update-backup-policy(bool, int, int, int);
    callback reminder-enabled-edited(bool);
    callback reminder-preset-edited(int, bool);
    callback reminder-custom-lead-edited(int, bool, int, int);
    callback save-reminder-policy();
    callback reset-reminder-recommended();
    callback enable-current-user-startup();
    callback repair-current-user-startup();
    callback disable-current-user-startup();
    callback select-presentation-density(int);
    callback select-presentation-skin(int);
    callback select-presentation-color-scheme(int);
    callback select-presentation-layout(int);
    callback move-dashboard-board-row(int, int);
    callback set-dashboard-board-row-visible(int, bool);
    callback set-dashboard-board-row-collapsed(int, bool);
    callback reset-dashboard-board();

    background: UiTokens.background;
    accessible-role: groupbox;
    accessible-label: "TokenMaster settings";

    presentation-strip := Rectangle {
        width: root.width;
        height: root.settings-layout-mode == "wide" ? 88px : 116px;
        background: UiTokens.background;

        density-label := Text {
            x: 8px;
            y: 8px;
            width: 64px;
            height: 32px;
            text: "Density";
            color: UiTokens.text-secondary;
            vertical-alignment: center;
        }
        density-selector := ComboBox {
            x: 80px;
            y: 8px;
            width: root.settings-layout-mode == "wide" ? root.width / 4 - 88px : root.width / 2 - 88px;
            height: 32px;
            model: ["Comfortable", "Compact", "Ultra compact"];
            current-index: root.presentation-density-id;
            accessible-label: "Presentation density";
            selected(_) => { root.select-presentation-density(self.current-index); }
        }
        skin-label := Text {
            x: root.settings-layout-mode == "wide" ? root.width / 4 + 8px : root.width / 2 + 8px;
            y: 8px;
            width: 40px;
            height: 32px;
            text: "Skin";
            color: UiTokens.text-secondary;
            vertical-alignment: center;
        }
        skin-selector := ComboBox {
            x: root.settings-layout-mode == "wide" ? root.width / 4 + 56px : root.width / 2 + 56px;
            y: 8px;
            width: root.settings-layout-mode == "wide" ? root.width / 4 - 64px : root.width / 2 - 64px;
            height: 32px;
            model: ["Refined", "Graphite", "Ember"];
            current-index: root.presentation-skin-id;
            accessible-label: "Presentation skin";
            selected(_) => { root.select-presentation-skin(self.current-index); }
        }
        scheme-label := Text {
            x: root.settings-layout-mode == "wide" ? 2 * root.width / 4 + 8px : 8px;
            y: root.settings-layout-mode == "wide" ? 8px : 44px;
            width: 56px;
            height: 32px;
            text: "Scheme";
            color: UiTokens.text-secondary;
            vertical-alignment: center;
        }
        scheme-selector := ComboBox {
            x: root.settings-layout-mode == "wide" ? 2 * root.width / 4 + 72px : 80px;
            y: root.settings-layout-mode == "wide" ? 8px : 44px;
            width: root.settings-layout-mode == "wide" ? root.width / 4 - 80px : root.width / 2 - 88px;
            height: 32px;
            model: ["System", "Light", "Dark"];
            current-index: root.presentation-color-scheme-id;
            accessible-label: "Presentation color scheme";
            selected(_) => { root.select-presentation-color-scheme(self.current-index); }
        }
        layout-label := Text {
            x: root.settings-layout-mode == "wide" ? 3 * root.width / 4 + 8px : root.width / 2 + 8px;
            y: root.settings-layout-mode == "wide" ? 8px : 44px;
            width: 56px;
            height: 32px;
            text: "Layout";
            color: UiTokens.text-secondary;
            vertical-alignment: center;
        }
        layout-selector := ComboBox {
            x: root.settings-layout-mode == "wide" ? 3 * root.width / 4 + 72px : root.width / 2 + 72px;
            y: root.settings-layout-mode == "wide" ? 8px : 44px;
            width: root.settings-layout-mode == "wide" ? root.width / 4 - 80px : root.width / 2 - 80px;
            height: 32px;
            model: ["Refined", "Control center", "Workbench"];
            current-index: root.presentation-layout-id;
            accessible-label: "Presentation layout";
            selected(_) => { root.select-presentation-layout(self.current-index); }
        }
        persistence-label := Text {
            x: 8px;
            y: root.settings-layout-mode == "wide" ? 48px : 84px;
            width: root.width - 16px;
            height: 24px;
            text: root.presentation-persistence-state == "saved" ? "Saved"
                : root.presentation-persistence-state == "saving" ? "Saving…"
                : "Not saved — choose the current presentation again to retry";
            color: UiTokens.text-secondary;
            accessible-label: "Presentation persistence " + self.text;
        }
    }

    settings-scroll := ScrollView {
        y: presentation-strip.height;
        width: root.width;
        height: root.height - presentation-strip.height;
        viewport := VerticalLayout {
        padding: UiTokens.space;
        spacing: UiTokens.space;

        Text { text: "Settings"; color: UiTokens.text-primary; font-size: 24px; font-weight: 700; }
        Text { text: "Settings health: " + root.settings-health; color: UiTokens.text-secondary; }

        board-card := Rectangle {
            background: UiTokens.surface;
            border-color: UiTokens.border;
            border-width: root.high-contrast ? 2px : 1px;
            border-radius: UiTokens.radius;
            accessible-role: groupbox;
            accessible-label: "Dashboard board";

            VerticalLayout {
                padding: UiTokens.space;
                spacing: UiTokens.space-sm;
                HorizontalLayout {
                    Text { text: "Dashboard board"; color: UiTokens.text-primary; font-size: 17px; font-weight: 650; horizontal-stretch: 1; }
                    Button {
                        text: "Reset board";
                        accessible-label: "Reset dashboard board";
                        clicked => { root.reset-dashboard-board(); }
                    }
                }
                Text {
                    text: "Order, visibility, and collapse are saved with the current presentation.";
                    color: UiTokens.text-secondary;
                    wrap: word-wrap;
                }
                for row[index] in root.board-editor-rows: Rectangle {
                    min-height: root.settings-layout-mode == "narrow" ? 84px : 36px;
                    background: UiTokens.surface-subtle;
                    border-radius: UiTokens.radius-sm;
                    accessible-role: groupbox;
                    accessible-label: "Dashboard board section " + row.label;
                    if root.settings-layout-mode == "narrow": VerticalLayout {
                        padding: UiTokens.space-xs;
                        spacing: UiTokens.space-xs;
                        Text { text: row.label; color: UiTokens.text-primary; font-weight: 650; }
                        HorizontalLayout {
                            spacing: UiTokens.space-xs;
                            Button { text: "Up"; enabled: row.can-move-up; accessible-label: "Move " + row.label + " up"; clicked => { root.move-dashboard-board-row(index, -1); } }
                            Button { text: "Down"; enabled: row.can-move-down; accessible-label: "Move " + row.label + " down"; clicked => { root.move-dashboard-board-row(index, 1); } }
                            CheckBox { text: "Visible"; checked: row.visible; enabled: row.visible || row.can-hide; accessible-label: "Show " + row.label + " on dashboard"; toggled => { root.set-dashboard-board-row-visible(index, self.checked); } }
                            CheckBox { text: "Collapsed"; checked: row.collapsed; accessible-label: "Collapse " + row.label + " on dashboard"; toggled => { root.set-dashboard-board-row-collapsed(index, self.checked); } }
                        }
                    }
                    if root.settings-layout-mode == "wide": HorizontalLayout {
                        padding-left: UiTokens.space-sm;
                        padding-right: UiTokens.space-sm;
                        spacing: UiTokens.space-sm;
                        Text { text: row.label; color: UiTokens.text-primary; font-weight: 650; horizontal-stretch: 1; vertical-alignment: center; }
                        Button { text: "Up"; enabled: row.can-move-up; accessible-label: "Move " + row.label + " up"; clicked => { root.move-dashboard-board-row(index, -1); } }
                        Button { text: "Down"; enabled: row.can-move-down; accessible-label: "Move " + row.label + " down"; clicked => { root.move-dashboard-board-row(index, 1); } }
                        CheckBox { text: "Visible"; checked: row.visible; enabled: row.visible || row.can-hide; accessible-label: "Show " + row.label + " on dashboard"; toggled => { root.set-dashboard-board-row-visible(index, self.checked); } }
                        CheckBox { text: "Collapsed"; checked: row.collapsed; accessible-label: "Collapse " + row.label + " on dashboard"; toggled => { root.set-dashboard-board-row-collapsed(index, self.checked); } }
                    }
                }
            }
        }

        reminder-card := Rectangle {
            background: UiTokens.surface;
            border-color: UiTokens.border;
            border-width: root.high-contrast ? 2px : 1px;
            border-radius: UiTokens.radius;

            reminder-content := VerticalLayout {
                padding: UiTokens.space;
                spacing: UiTokens.space-sm;
                Text { text: "Expiry reminders"; color: UiTokens.text-primary; font-size: 17px; font-weight: 650; }
                Text { text: "Sync state: " + root.reminder-sync-state; color: UiTokens.text-secondary; accessible-label: "Reminder synchronization state " + root.reminder-sync-state; }
                reminder-enabled-control := CheckBox { text: "Enable expiry reminders"; checked: root.reminder-enabled; accessible-label: "Enable expiry reminders"; toggled => { root.reminder-enabled-edited(self.checked); } }
                Text { text: "Recommended lead times"; color: UiTokens.text-secondary; }
                presets := VerticalLayout {
                    spacing: 2px;
                    CheckBox { text: "7 days"; checked: root.reminder-preset-seven-days; accessible-label: "Reminder lead time 7 days"; toggled => { root.reminder-preset-edited(0, self.checked); } }
                    CheckBox { text: "24 hours"; checked: root.reminder-preset-twenty-four-hours; accessible-label: "Reminder lead time 24 hours"; toggled => { root.reminder-preset-edited(1, self.checked); } }
                    CheckBox { text: "12 hours"; checked: root.reminder-preset-twelve-hours; accessible-label: "Reminder lead time 12 hours"; toggled => { root.reminder-preset-edited(2, self.checked); } }
                    CheckBox { text: "6 hours"; checked: root.reminder-preset-six-hours; accessible-label: "Reminder lead time 6 hours"; toggled => { root.reminder-preset-edited(3, self.checked); } }
                    CheckBox { text: "1 hour"; checked: root.reminder-preset-one-hour; accessible-label: "Reminder lead time 1 hour"; toggled => { root.reminder-preset-edited(4, self.checked); } }
                }
                Text { text: "Custom lead times"; color: UiTokens.text-secondary; }
                for row[index] in root.reminder-custom-lead-rows: HorizontalLayout {
                    spacing: UiTokens.space-sm;
                    row-enabled := CheckBox { text: "Custom lead"; checked: row.enabled; accessible-label: "Enable custom reminder lead row " + (index + 1); toggled => { root.reminder-custom-lead-edited(index, self.checked, value.value, unit.current-index); } }
                    value := SpinBox { minimum: 1; maximum: 2147483647; value: row.value; accessible-label: "Custom reminder lead value row " + (index + 1); edited(v) => { root.reminder-custom-lead-edited(index, row-enabled.checked, v, unit.current-index); } }
                    unit := ComboBox { model: ["seconds", "minutes", "hours", "days"]; current-index: row.unit-index; accessible-label: "Custom reminder lead unit row " + (index + 1); selected(_) => { root.reminder-custom-lead-edited(index, row-enabled.checked, value.value, self.current-index); } }
                }
                HorizontalLayout {
                    spacing: UiTokens.space-sm;
                    Button { text: "Save reminder profile"; accessible-label: "Save reminder profile"; clicked => { root.save-reminder-policy(); } }
                    Button { text: "Reset to recommended"; accessible-label: "Reset reminder profile to recommended"; clicked => { root.reset-reminder-recommended(); } }
                }
                Text { text: root.reminder-feedback; color: UiTokens.text-secondary; accessible-label: "Reminder editor feedback " + root.reminder-feedback; }
            }
        }

        backup-card := Rectangle {
            height: root.settings-layout-mode == "narrow" ? 330px : 214px;
            background: UiTokens.surface;
            border-color: UiTokens.border;
            border-width: root.high-contrast ? 2px : 1px;
            border-radius: UiTokens.radius;

            VerticalLayout {
                padding: UiTokens.space;
                spacing: UiTokens.space-sm;
                Text { text: "Automatic backup policy"; color: UiTokens.text-primary; font-size: 17px; font-weight: 650; }
                enabled := CheckBox { text: "Enable periodic backups"; checked: root.periodic-enabled; accessible-label: "Enable periodic backups"; }
                GridLayout {
                    spacing: UiTokens.space-sm;
                    Text { row: 0; col: 0; text: "Quiet seconds"; color: UiTokens.text-secondary; vertical-alignment: center; }
                    quiet := SpinBox { row: 0; col: 1; minimum: 300; maximum: 3600; value: root.quiet-seconds; accessible-label: "Backup quiet period in seconds"; }
                    Text { row: root.settings-layout-mode == "wide" ? 0 : 1; col: root.settings-layout-mode == "wide" ? 2 : 0; text: "Interval seconds"; color: UiTokens.text-secondary; vertical-alignment: center; }
                    interval := SpinBox { row: root.settings-layout-mode == "wide" ? 0 : 1; col: root.settings-layout-mode == "wide" ? 3 : 1; minimum: 21600; maximum: 604800; value: root.interval-seconds; accessible-label: "Backup interval in seconds"; }
                    Text { row: root.settings-layout-mode == "wide" ? 0 : 2; col: root.settings-layout-mode == "wide" ? 4 : 0; text: "Budget MiB"; color: UiTokens.text-secondary; vertical-alignment: center; }
                    budget := SpinBox { row: root.settings-layout-mode == "wide" ? 0 : 2; col: root.settings-layout-mode == "wide" ? 5 : 1; minimum: 256; maximum: 65536; value: root.retention-budget-mib; accessible-label: "Backup retention budget in mebibytes"; }
                }
                Button { text: "Save backup policy"; accessible-label: "Save automatic backup policy"; clicked => { root.update-backup-policy(enabled.checked, quiet.value, interval.value, budget.value); } }
            }
        }

        startup-card := Rectangle {
            height: root.current-user-startup-status == "stale_relocation" ? 190px : 146px;
            background: UiTokens.surface;
            border-color: UiTokens.border;
            border-width: root.high-contrast ? 2px : 1px;
            border-radius: UiTokens.radius;

            VerticalLayout {
                padding: UiTokens.space;
                spacing: UiTokens.space-sm;
                Text { text: "Start with Windows"; color: UiTokens.text-primary; font-size: 17px; font-weight: 650; }
                Text {
                    text: root.current-user-startup-status == "disabled" ? "Disabled. TokenMaster will not start when you sign in."
                        : root.current-user-startup-status == "enabled_verified" ? "Enabled and verified for this executable."
                        : root.current-user-startup-status == "stale_relocation" ? "The registration points to a previous TokenMaster location. Repair or remove it explicitly."
                        : root.current-user-startup-status == "conflict" ? "A conflicting startup value is present. TokenMaster will not overwrite it."
                        : root.current-user-startup-status == "access_denied" ? "Windows denied access to the current-user startup value."
                        : "Current-user startup is unavailable on this system.";
                    color: root.current-user-startup-status == "enabled_verified" ? UiTokens.ready : root.current-user-startup-status == "disabled" ? UiTokens.text-secondary : UiTokens.degraded;
                    wrap: word-wrap;
                    horizontal-stretch: 1;
                    accessible-label: "Current-user startup status " + root.current-user-startup-status;
                }
                HorizontalLayout {
                    spacing: UiTokens.space-sm;
                    if root.current-user-startup-can-enable: Button {
                        text: "Enable at sign-in";
                        accessible-label: "Enable TokenMaster at Windows sign-in";
                        clicked => { root.enable-current-user-startup(); }
                    }
                    if root.current-user-startup-can-disable && !root.current-user-startup-can-repair: Button {
                        text: "Disable at sign-in";
                        accessible-label: "Disable TokenMaster at Windows sign-in";
                        clicked => { root.disable-current-user-startup(); }
                    }
                    if root.current-user-startup-can-repair: Button {
                        text: "Repair registration";
                        accessible-label: "Repair TokenMaster startup registration";
                        clicked => { root.repair-current-user-startup(); }
                    }
                    if root.current-user-startup-can-repair: Button {
                        text: "Remove old registration";
                        accessible-label: "Remove old TokenMaster startup registration";
                        clicked => { root.disable-current-user-startup(); }
                    }
                }
            }
        }

        config-card := Rectangle {
            height: root.config-import-preview-visible ? 182px : 118px;
            background: UiTokens.surface;
            border-color: UiTokens.border;
            border-width: root.high-contrast ? 2px : 1px;
            border-radius: UiTokens.radius;
            VerticalLayout {
                padding: UiTokens.space;
                spacing: UiTokens.space-sm;
                Text { text: "Portable configuration"; color: UiTokens.text-primary; font-size: 17px; font-weight: 650; }
                HorizontalLayout {
                    spacing: UiTokens.space-sm;
                    Button { text: "Export configuration"; accessible-label: "Export TokenMaster configuration"; clicked => { root.export-config(); } }
                    Button { text: "Import configuration"; accessible-label: "Import TokenMaster configuration"; clicked => { root.import-config(); } }
                }
                if root.config-import-preview-visible: HorizontalLayout {
                    spacing: UiTokens.space-sm;
                    Text {
                        text: "Import review · " + root.config-import-created-label + " · " + root.config-import-bytes-label + " · " + root.config-import-changes-label;
                        color: UiTokens.degraded;
                        horizontal-stretch: 1;
                        wrap: word-wrap;
                    }
                    Button { text: "Apply"; accessible-label: "Apply reviewed configuration import"; clicked => { root.confirm-config-import(); } }
                    Button { text: "Discard"; accessible-label: "Discard reviewed configuration import"; clicked => { root.cancel-config-import(); } }
                }
            }
        }
        Text { text: root.reduced-motion ? "Reduced motion enabled" : "Reduced motion ready"; color: UiTokens.text-secondary; font-size: 12px; }
        Rectangle { vertical-stretch: 1; background: transparent; }
        }
    }
}
