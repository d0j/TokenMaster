export global UiTokens {
    in-out property <int> density-id: 0;
    out property <color> background: #0b0f17;
    out property <color> surface: #111827;
    out property <color> surface-raised: #182234;
    out property <color> surface-subtle: #0e1624;
    out property <color> border: #293548;
    out property <color> text-primary: #f4f7fb;
    out property <color> text-secondary: #9eabc0;
    out property <color> accent: #7cd4fd;
    out property <color> accent-subtle: #173044;
    out property <color> accent-secondary: #a78bfa;
    out property <color> accent-tertiary: #f0abfc;
    out property <color> ready: #70d6a5;
    out property <color> waiting: #8fa3bf;
    out property <color> degraded: #f2c66d;
    out property <color> unavailable: #f08b8b;
    out property <length> space-xs: density-id == 2 ? 2px : (density-id == 1 ? 3px : 4px);
    out property <length> space-sm: density-id == 2 ? 4px : (density-id == 1 ? 6px : 8px);
    out property <length> space: density-id == 2 ? 8px : (density-id == 1 ? 12px : 16px);
    out property <length> space-lg: 24px;
    out property <length> radius-sm: density-id == 2 ? 3px : (density-id == 1 ? 4px : 5px);
    out property <length> radius: density-id == 2 ? 4px : (density-id == 1 ? 6px : 8px);
    out property <length> radius-lg: density-id == 2 ? 6px : (density-id == 1 ? 9px : 12px);
}
