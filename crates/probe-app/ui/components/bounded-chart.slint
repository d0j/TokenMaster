import { ChartPoint } from "../models.slint";
import { Theme } from "../tokens.slint";

export component BoundedChart inherits Rectangle {
    in property <[ChartPoint]> points;
    min-height: 160px;
    background: Theme.surface;
    border-color: Theme.border;
    border-width: 1px;
    border-radius: Theme.radius;
    accessible-role: image;
    accessible-label: @tr("Usage trend");

    for point[i] in root.points: Rectangle {
        x: i * (root.width / root.points.length);
        y: root.height - self.height - Theme.spacing;
        width: root.width / root.points.length - 1px;
        height: point.value * (root.height - 2 * Theme.spacing);
        background: Theme.accent;
        border-radius: 1px;
    }
}
